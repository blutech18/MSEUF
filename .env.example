# Convex
NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud

# Google Drive API Configuration
# Service Account JSON (entire JSON object as a single line string)
GOOGLE_DRIVE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"your-project-id","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"your-service-account@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}'

# Google Drive Folder ID (extract from your folder URL)
# Example: https://drive.google.com/drive/folders/1ysQmcabRD5kI5kLzWTI60BJH_mHbVRFh
# The folder ID is: 1ysQmcabRD5kI5kLzWTI60BJH_mHbVRFh
GOOGLE_DRIVE_FOLDER_ID=1ysQmcabRD5kI5kLzWTI60BJH_mHbVRFh

# OpenAI (if using)
OPENAI_API_KEY=

# Google AI (if using)
GOOGLE_AI_API_KEY=
